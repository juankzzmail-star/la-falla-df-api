# ── Base de datos ────────────────────────────────────────────────────────────
# Postgres en EasyPanel. Reemplaza user/pass/host/dbname con los valores reales.
DATABASE_URL=postgresql://lafalla:PASSWORD@postgres:5432/falla_db

# ── API FastAPI ───────────────────────────────────────────────────────────────
# Clave secreta compartida entre N8N y la API. Genera una con: openssl rand -hex 32
FASTAPI_API_KEY=cambia_esto_por_una_clave_segura

# ── N8N ───────────────────────────────────────────────────────────────────────
N8N_HOST=https://la-falla-df-n8n.7ubo23.easypanel.host
N8N_API_KEY=

# URL base de la API (desde N8N usa el nombre de servicio interno de EasyPanel)
FASTAPI_BASE_URL=http://api-stakeholders:8000

# ── Chatwoot ──────────────────────────────────────────────────────────────────
# URL pública del servicio Chatwoot en EasyPanel
CHATWOOT_URL=https://la-falla-df-chatwoot.7ubo23.easypanel.host

# Token de acceso: Chatwoot → Settings → Access Token (esquina inferior izquierda)
CHATWOOT_API_TOKEN=

# ID de la cuenta (generalmente 1 en instalaciones nuevas)
CHATWOOT_ACCOUNT_ID=1

# URL base completa de la API — N8N usa esta variable directamente
# Formato: <CHATWOOT_URL>/api/v1/accounts/<CHATWOOT_ACCOUNT_ID>
CHATWOOT_API_BASE=https://la-falla-df-chatwoot.7ubo23.easypanel.host/api/v1/accounts/1

# ID del inbox de WhatsApp en Chatwoot
# (Chatwoot → Settings → Inboxes → WhatsApp → ver el ID en la URL)
CHATWOOT_WA_INBOX_ID=

# ID de la conversación de Juan Carlos en Chatwoot
# El bot usa este ID para enviar resúmenes y notificaciones proactivas a JC
# Obtenerlo: abrir conversación de JC en Chatwoot y ver el número en la URL
CHATWOOT_JUAN_CONVERSATION_ID=

# Números autorizados para enviar contactos al bot (separados por coma, sin espacios)
# Formato: código país + número, ej: 573001234567
AUTHORIZED_WA_NUMBERS=573001234567,573009876543

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Gemini (opcional) ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
